APP_NAME=高翠网 API
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+asyncpg://<postgres_user>:<postgres_password>@127.0.0.1:55432/<postgres_db>
SYNC_DATABASE_URL=postgresql://<postgres_user>:<postgres_password>@127.0.0.1:55432/<postgres_db>
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=<replace-with-local-secret>
DEEPSEEK_API_KEY=<replace-with-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
