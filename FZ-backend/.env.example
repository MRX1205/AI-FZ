APP_NAME=高翠网 API
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+asyncpg://<postgres_user>:<postgres_password>@127.0.0.1:55432/<postgres_db>
SYNC_DATABASE_URL=postgresql://<postgres_user>:<postgres_password>@127.0.0.1:55432/<postgres_db>
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=<replace-with-local-secret>
MIMO_API_KEY=<replace-with-mimo-api-key>
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
DASHSCOPE_API_KEY=<replace-with-dashscope-api-key>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
